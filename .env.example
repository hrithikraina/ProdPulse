# Azure OpenAI resource and deployment configuration
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# Used by the LangGraph RCA workflow; can be the same value as CHAT_DEPLOYMENT.
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# Optional integrations
# GITHUB_REPOSITORY=owner/repository
# GITHUB_TOKEN=replace-with-your-github-token
# GITHUB_PAT=replace-with-your-github-personal-access-token
# SQLITE_DB_PATH=PaymentsPlatform.db
